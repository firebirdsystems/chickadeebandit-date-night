{
  "manifest": {
    "id": "date-night-planner",
    "name": "Date Night Planner",
    "version": "1.0.0",
    "description": "Build a shared catalog of date ideas and let the app pick one when you need inspiration.",
    "entrypoint": "index.html",
    "runtime": "static",
    "category": "couple",
    "tags": [
      "couples"
    ],
    "data_access": {
      "reads": [
        "family.members"
      ],
      "writes": []
    },
    "permissions": {
      "default_audience": "adults",
      "requires_approval": false
    },
    "storage": "db",
    "icon": "🌙",
    "nav": {
      "label": "Date Nights"
    }
  },
  "migrations": [
    {
      "version": 1,
      "sql": "CREATE TABLE IF NOT EXISTS partner_config (\n  member_id TEXT NOT NULL,\n  household_id UUID NOT NULL DEFAULT current_setting('app.household_id', true)::uuid,\n  partner_id TEXT NOT NULL,\n  PRIMARY KEY (member_id, household_id)\n);\n\nCREATE TABLE IF NOT EXISTS date_ideas (\n  id TEXT PRIMARY KEY,\n  household_id UUID NOT NULL DEFAULT current_setting('app.household_id', true)::uuid,\n  created_by TEXT NOT NULL,\n  title TEXT NOT NULL,\n  notes TEXT,\n  tags TEXT,\n  done_at TEXT,\n  rating INTEGER,\n  created_at TEXT NOT NULL\n);"
    }
  ],
  "files": {
    "index.html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <base href=\"/run/date-night-planner/\" />\n  <title>Date Night Planner</title>\n  <style>\n    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n    body {\n      font-family: var(--hub-font, system-ui, sans-serif);\n      font-size: var(--hub-font-size, 15px);\n      background: var(--hub-bg, #f9fafb);\n      color: var(--hub-text, #111827);\n      min-height: 100vh;\n    }\n\n    .view { display: none; }\n    .view.active { display: block; }\n\n    /* ── App header ── */\n    .app-header {\n      display: flex; align-items: center; justify-content: space-between;\n      padding: 16px 20px 0;\n    }\n    .app-header-left { display: flex; align-items: center; gap: 8px; }\n    .app-header .icon { font-size: 1.3rem; }\n    .app-header h1 { font-size: 1.25rem; font-weight: 700; }\n\n    /* ── Setup view ── */\n    .setup-wrap {\n      display: flex; flex-direction: column; align-items: center;\n      padding: 48px 20px; min-height: 80vh; justify-content: center;\n    }\n    .setup-card {\n      background: var(--hub-surface, #fff);\n      border: 1px solid var(--hub-border, #e5e7eb);\n      border-radius: var(--hub-radius, 8px);\n      padding: 32px; max-width: 420px; width: 100%; text-align: center;\n    }\n    .setup-icon { font-size: 2.5rem; margin-bottom: 16px; }\n    .setup-card h2 { font-size: 1.2rem; font-weight: 700; margin-bottom: 6px; }\n    .setup-card .setup-desc { color: var(--hub-text-muted, #6b7280); font-size: 0.9rem; margin-bottom: 24px; }\n    .setup-card .pick-label { font-weight: 600; margin-bottom: 12px; text-align: left; display: block; }\n    .member-list { margin-bottom: 20px; }\n    .member-option {\n      display: flex; align-items: center; gap: 10px;\n      padding: 10px 12px;\n      border: 1px solid var(--hub-border, #e5e7eb);\n      border-radius: var(--hub-radius, 6px);\n      cursor: pointer; margin-bottom: 6px;\n      transition: border-color .15s, background .15s; text-align: left;\n    }\n    .member-option input[type=\"radio\"] { accent-color: var(--hub-primary, #6366f1); }\n    .member-option:has(input:checked) {\n      border-color: var(--hub-primary, #6366f1);\n      background: color-mix(in srgb, var(--hub-primary, #6366f1) 6%, transparent);\n    }\n    .member-avatar { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; color: #fff; flex-shrink: 0; }\n    .member-name { font-weight: 500; font-size: 0.95rem; }\n\n    /* ── Tabs ── */\n    .tabs { display: flex; gap: 0; border-bottom: 1px solid var(--hub-border, #e5e7eb); margin: 14px 20px 0; }\n    .tab-btn {\n      padding: 8px 16px; background: transparent; border: none; cursor: pointer;\n      font-family: inherit; font-size: 0.9rem; font-weight: 500;\n      color: var(--hub-text-muted, #6b7280);\n      border-bottom: 2px solid transparent; margin-bottom: -1px;\n      transition: color .15s, border-color .15s;\n    }\n    .tab-btn.active { color: var(--hub-primary, #6366f1); border-bottom-color: var(--hub-primary, #6366f1); }\n    .tab-panel { display: none; padding: 16px 20px; }\n    .tab-panel.active { display: block; }\n\n    /* ── Surprise banner ── */\n    .surprise-bar {\n      background: var(--hub-surface, #fff);\n      border: 1px solid var(--hub-border, #e5e7eb);\n      border-radius: var(--hub-radius, 8px);\n      padding: 14px 16px;\n      margin-bottom: 16px;\n      display: flex; align-items: center; justify-content: space-between; gap: 12px;\n    }\n    .surprise-bar p { font-size: 0.9rem; color: var(--hub-text-muted, #6b7280); }\n\n    /* ── Idea cards ── */\n    .ideas-list { display: flex; flex-direction: column; gap: 10px; }\n    .idea-card {\n      background: var(--hub-surface, #fff);\n      border: 1px solid var(--hub-border, #e5e7eb);\n      border-radius: var(--hub-radius, 8px);\n      padding: 14px 16px;\n    }\n    .idea-card.done { opacity: .6; }\n    .idea-header { display: flex; align-items: flex-start; gap: 8px; margin-bottom: 6px; }\n    .idea-title { font-weight: 600; font-size: 0.95rem; flex: 1; }\n    .idea-notes { font-size: 0.875rem; color: var(--hub-text-muted, #6b7280); margin-bottom: 8px; white-space: pre-wrap; word-break: break-word; }\n    .idea-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 8px; }\n    .idea-tag { padding: 2px 8px; border-radius: 999px; background: var(--hub-bg, #f9fafb); border: 1px solid var(--hub-border, #e5e7eb); font-size: 0.78rem; color: var(--hub-text-muted, #6b7280); }\n    .idea-footer { display: flex; align-items: center; justify-content: space-between; }\n    .idea-meta { font-size: 0.8rem; color: var(--hub-text-muted, #6b7280); }\n    .stars { color: #f59e0b; letter-spacing: 2px; }\n\n    /* ── Empty state ── */\n    .empty-state { text-align: center; padding: 48px 20px; color: var(--hub-text-muted, #6b7280); }\n    .empty-state .empty-icon { font-size: 2rem; margin-bottom: 12px; }\n    .empty-state p { font-size: 0.95rem; }\n\n    /* ── Reveal modal (Surprise Me) ── */\n    .reveal-card {\n      text-align: center; padding: 8px 0 16px;\n    }\n    .reveal-emoji { font-size: 2.5rem; margin-bottom: 12px; }\n    .reveal-title { font-size: 1.3rem; font-weight: 700; margin-bottom: 8px; }\n    .reveal-tags { display: flex; gap: 6px; flex-wrap: wrap; justify-content: center; margin-bottom: 8px; }\n    .reveal-notes { font-size: 0.9rem; color: var(--hub-text-muted, #6b7280); margin-bottom: 16px; white-space: pre-wrap; }\n    .reveal-actions { display: flex; gap: 8px; justify-content: center; }\n\n    /* ── Tag chips (add form) ── */\n    .tag-chips { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 6px; }\n    .tag-chip {\n      padding: 4px 10px; border-radius: 999px;\n      border: 1px solid var(--hub-border, #e5e7eb);\n      background: var(--hub-bg, #f9fafb);\n      font-size: 0.82rem; cursor: pointer; transition: background .15s, border-color .15s;\n    }\n    .tag-chip.selected {\n      background: color-mix(in srgb, var(--hub-primary, #6366f1) 12%, transparent);\n      border-color: var(--hub-primary, #6366f1);\n      color: var(--hub-primary, #6366f1); font-weight: 600;\n    }\n\n    /* ── Buttons ── */\n    .btn-primary {\n      background: var(--hub-primary, #6366f1); color: var(--hub-primary-fg, #fff);\n      border: none; border-radius: var(--hub-radius, 6px);\n      padding: 10px 20px; font-size: 0.95rem; font-weight: 600; cursor: pointer;\n      transition: opacity .15s; display: inline-flex; align-items: center; gap: 6px;\n    }\n    .btn-primary:hover:not(:disabled) { opacity: .85; }\n    .btn-primary:disabled { opacity: .5; cursor: not-allowed; }\n    .btn-secondary {\n      background: transparent; color: var(--hub-text, #111827);\n      border: 1px solid var(--hub-border, #e5e7eb);\n      border-radius: var(--hub-radius, 6px);\n      padding: 10px 20px; font-size: 0.95rem; font-weight: 500; cursor: pointer;\n    }\n    .btn-secondary:hover { background: var(--hub-bg, #f9fafb); }\n    .btn-ghost {\n      background: transparent; border: none; cursor: pointer;\n      color: var(--hub-text-muted, #6b7280); font-size: 0.85rem; padding: 4px 8px;\n      border-radius: var(--hub-radius, 4px);\n    }\n    .btn-ghost:hover { background: var(--hub-bg, #f9fafb); color: var(--hub-text, #111827); }\n    .btn-icon {\n      background: transparent; border: none; cursor: pointer;\n      color: var(--hub-text-muted, #6b7280); padding: 6px;\n      border-radius: var(--hub-radius, 4px); font-size: 1rem; line-height: 1;\n    }\n    .btn-icon:hover { color: var(--hub-text, #111827); background: var(--hub-bg, #f9fafb); }\n\n    /* ── Modal ── */\n    .modal-backdrop {\n      position: fixed; inset: 0; background: rgba(0,0,0,.45);\n      display: flex; align-items: center; justify-content: center; z-index: 1000; padding: 20px;\n    }\n    .modal {\n      background: var(--hub-surface, #fff);\n      border-radius: var(--hub-radius, 8px);\n      padding: 24px; width: 100%; max-width: 460px;\n      box-shadow: 0 8px 32px rgba(0,0,0,.18);\n      max-height: 90vh; overflow-y: auto;\n    }\n    .modal h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 16px; }\n    .form-group { margin-bottom: 14px; }\n    .form-group label { display: block; font-weight: 500; margin-bottom: 5px; font-size: 0.9rem; }\n    .form-group input, .form-group textarea {\n      width: 100%; padding: 9px 12px;\n      border: 1px solid var(--hub-border, #e5e7eb);\n      border-radius: var(--hub-radius, 6px);\n      background: var(--hub-bg, #f9fafb);\n      color: var(--hub-text, #111827);\n      font-family: inherit; font-size: inherit;\n    }\n    .form-group input:focus, .form-group textarea:focus { outline: 2px solid var(--hub-primary, #6366f1); outline-offset: 1px; }\n    .form-group textarea { resize: vertical; min-height: 80px; }\n    .star-row { display: flex; gap: 6px; }\n    .star-btn { background: transparent; border: none; cursor: pointer; font-size: 1.4rem; padding: 2px; line-height: 1; transition: transform .1s; }\n    .star-btn:hover { transform: scale(1.15); }\n    .modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 16px; }\n  </style>\n</head>\n<body>\n\n  <!-- ── Setup view ── -->\n  <div id=\"view-setup\" class=\"view\">\n    <div class=\"setup-wrap\">\n      <div class=\"setup-card\">\n        <div class=\"setup-icon\">🌙</div>\n        <h2>Date Night Planner</h2>\n        <p class=\"setup-desc\">Build a shared list of date ideas. Tap \"Surprise Me\" whenever you need inspiration.</p>\n        <span class=\"pick-label\">Who is your partner?</span>\n        <div id=\"setup-members\" class=\"member-list\"></div>\n        <button class=\"btn-primary\" style=\"width:100%;justify-content:center\" onclick=\"savePartner()\">Get Started</button>\n      </div>\n    </div>\n  </div>\n\n  <!-- ── Main view ── -->\n  <div id=\"view-main\" class=\"view\">\n    <div class=\"app-header\">\n      <div class=\"app-header-left\">\n        <span class=\"icon\">🌙</span>\n        <h1>Date Nights</h1>\n      </div>\n      <div style=\"display:flex;align-items:center;gap:8px\">\n        <button class=\"btn-icon\" title=\"Change partner\" onclick=\"showSetup()\">⚙️</button>\n        <button class=\"btn-primary\" onclick=\"openAddIdea()\">+ Add Idea</button>\n      </div>\n    </div>\n    <div class=\"tabs\">\n      <button class=\"tab-btn active\" onclick=\"switchTab('ideas',this)\">Ideas</button>\n      <button class=\"tab-btn\" onclick=\"switchTab('history',this)\">History</button>\n    </div>\n    <div id=\"tab-ideas\" class=\"tab-panel active\">\n      <div class=\"surprise-bar\">\n        <p>Not sure what to do? Let us pick.</p>\n        <button class=\"btn-primary\" onclick=\"surpriseMe()\">✨ Surprise Me</button>\n      </div>\n      <div id=\"ideas-list\" class=\"ideas-list\"></div>\n    </div>\n    <div id=\"tab-history\" class=\"tab-panel\">\n      <div id=\"history-list\" class=\"ideas-list\"></div>\n    </div>\n  </div>\n\n  <script type=\"module\">\n    import { esc, initial, memberColor, formatRelativeDate } from \"/hub-sdk.js\";\n    import { TAGS, validateIdea, parseTags, pickRandom } from \"./logic.js\";\n\n    const CONTEXT = window.__CONTEXT_URL ?? \"\";\n    const DB      = window.__DB_URL      ?? \"\";\n    const ME      = window.__CURRENT_MEMBER ?? null;\n    const APP_ID  = window.__APP_ID ?? \"date-night-planner\";\n\n    let members  = [];\n    let partner  = null;\n    let ideas    = [];\n    let modalEl  = null;\n    let draftTags = [];\n\n    async function db(sql, params = []) {\n      if (!DB) return { rows: [] };\n      const res = await fetch(DB, {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ sql, params }),\n      });\n      return res.json();\n    }\n\n    async function loadMembers() {\n      if (!CONTEXT) {\n        members = [\n          { id: \"demo-1\", name: \"Alex\",   role: \"adult\" },\n          { id: \"demo-2\", name: \"Jordan\", role: \"adult\" },\n          { id: \"demo-3\", name: \"Sam\",    role: \"adult\" },\n        ];\n        return;\n      }\n      try {\n        const res = await fetch(`${CONTEXT}?keys=family.members`);\n        members = ((await res.json())[\"family.members\"]) ?? [];\n      } catch { members = []; }\n    }\n\n    async function loadPartner() {\n      if (!ME) return null;\n      const { rows } = await db(\n        \"SELECT partner_id FROM partner_config WHERE member_id = ?\",\n        [ME.id]\n      );\n      return rows.length ? (members.find(m => m.id === rows[0].partner_id) ?? null) : null;\n    }\n\n    async function loadIdeas() {\n      if (!ME || !partner) {\n        ideas = [\n          { id: \"d1\", created_by: \"demo-2\", title: \"Sunset picnic at the park\", notes: \"Bring the good blanket\", tags: '[\"outdoors\",\"budget\"]', done_at: null, rating: null, created_at: new Date(Date.now() - 86400000).toISOString() },\n          { id: \"d2\", created_by: \"demo-1\", title: \"Sushi at Nobu\", notes: \"\", tags: '[\"restaurant\"]', done_at: null, rating: null, created_at: new Date(Date.now() - 172800000).toISOString() },\n          { id: \"d3\", created_by: \"demo-2\", title: \"Movie marathon at home\", notes: \"Sci-fi theme\", tags: '[\"stay-in\"]', done_at: new Date(Date.now() - 604800000).toISOString(), rating: 5, created_at: new Date(Date.now() - 700000000).toISOString() },\n        ];\n        return;\n      }\n      const { rows } = await db(\n        \"SELECT * FROM date_ideas WHERE created_by IN (?, ?) ORDER BY created_at DESC\",\n        [ME.id, partner.id]\n      );\n      ideas = rows;\n    }\n\n    window.savePartner = async function() {\n      const sel = document.querySelector('#setup-members input[type=\"radio\"]:checked');\n      if (!sel) return;\n      const partnerId = sel.value;\n      const btn = document.querySelector('#view-setup .btn-primary');\n      if (btn) { btn.disabled = true; btn.textContent = \"Saving…\"; }\n      try {\n        if (ME) {\n          await db(\n            `INSERT INTO partner_config (member_id, partner_id) VALUES (?, ?)\n             ON CONFLICT (member_id, household_id) DO UPDATE SET partner_id = EXCLUDED.partner_id`,\n            [ME.id, partnerId]\n          );\n        }\n        partner = members.find(m => m.id === partnerId) ?? null;\n        await loadIdeas();\n        showMain();\n      } catch(e) {\n        if (btn) { btn.disabled = false; btn.textContent = \"Get Started\"; }\n        throw e;\n      }\n    };\n\n    // ── Modal helpers ─────────────────────────────────────────────────────────\n    function openModal(html) {\n      closeModal();\n      modalEl = document.createElement(\"div\");\n      modalEl.className = \"modal-backdrop\";\n      modalEl.innerHTML = `<div class=\"modal\">${html}</div>`;\n      modalEl.addEventListener(\"click\", e => { if (e.target === modalEl) closeModal(); });\n      document.body.appendChild(modalEl);\n    }\n    window.closeModal = function() { modalEl?.remove(); modalEl = null; };\n\n    // ── Add idea ──────────────────────────────────────────────────────────────\n    window.openAddIdea = function() {\n      draftTags = [];\n      openModal(`\n        <h3>Add Date Idea</h3>\n        <div class=\"form-group\">\n          <label>What's the idea?</label>\n          <input id=\"f-title\" type=\"text\" placeholder=\"e.g. Sunset picnic at the park\" />\n        </div>\n        <div class=\"form-group\">\n          <label>Notes <span style=\"color:var(--hub-text-muted,#6b7280);font-weight:400\">(optional)</span></label>\n          <textarea id=\"f-notes\" placeholder=\"Any details to remember…\"></textarea>\n        </div>\n        <div class=\"form-group\">\n          <label>Tags</label>\n          <div class=\"tag-chips\">\n            ${TAGS.map(t => `<button type=\"button\" class=\"tag-chip\" onclick=\"toggleTag('${t}',this)\">${t}</button>`).join(\"\")}\n          </div>\n        </div>\n        <div class=\"modal-actions\">\n          <button class=\"btn-secondary\" onclick=\"closeModal()\">Cancel</button>\n          <button class=\"btn-primary\" onclick=\"submitIdea()\">Add</button>\n        </div>\n      `);\n      document.getElementById(\"f-title\").focus();\n    };\n\n    window.toggleTag = function(tag, el) {\n      if (draftTags.includes(tag)) {\n        draftTags = draftTags.filter(t => t !== tag);\n        el.classList.remove(\"selected\");\n      } else {\n        draftTags.push(tag);\n        el.classList.add(\"selected\");\n      }\n    };\n\n    window.submitIdea = async function() {\n      const titleInput = document.getElementById(\"f-title\");\n      const result = validateIdea(titleInput?.value);\n      if (!result.valid) { titleInput?.focus(); return; }\n\n      const btn = modalEl?.querySelector(\".modal-actions .btn-primary\");\n      if (btn) { btn.disabled = true; btn.textContent = \"Adding…\"; }\n      try {\n        if (ME) {\n          await db(\n            \"INSERT INTO date_ideas (id, created_by, title, notes, tags, created_at) VALUES (?, ?, ?, ?, ?, ?)\",\n            [crypto.randomUUID(), ME.id, result.trimmed,\n             document.getElementById(\"f-notes\")?.value.trim() ?? \"\",\n             JSON.stringify(draftTags),\n             new Date().toISOString()]\n          );\n          await loadIdeas();\n        }\n        closeModal();\n        renderIdeas();\n      } catch(e) {\n        if (btn) { btn.disabled = false; btn.textContent = \"Add\"; }\n        throw e;\n      }\n    };\n\n    // ── Surprise Me ───────────────────────────────────────────────────────────\n    window.surpriseMe = function() {\n      const undone = ideas.filter(i => !i.done_at);\n      const pick = pickRandom(undone);\n      if (!pick) {\n        openModal(`\n          <div class=\"reveal-card\">\n            <div class=\"reveal-emoji\">🤔</div>\n            <div class=\"reveal-title\">No ideas yet!</div>\n            <p style=\"color:var(--hub-text-muted,#6b7280);font-size:.9rem;margin-bottom:16px\">Add some ideas first, then let us surprise you.</p>\n            <div class=\"reveal-actions\">\n              <button class=\"btn-primary\" onclick=\"closeModal();openAddIdea()\">Add an idea</button>\n            </div>\n          </div>\n        `);\n        return;\n      }\n      const tags = parseTags(pick.tags);\n      openModal(`\n        <div class=\"reveal-card\">\n          <div class=\"reveal-emoji\">🌙</div>\n          <div class=\"reveal-title\">${esc(pick.title)}</div>\n          ${tags.length ? `<div class=\"reveal-tags\">${tags.map(t => `<span class=\"idea-tag\">${esc(t)}</span>`).join(\"\")}</div>` : \"\"}\n          ${pick.notes ? `<div class=\"reveal-notes\">${esc(pick.notes)}</div>` : \"\"}\n          <div class=\"reveal-actions\">\n            <button class=\"btn-secondary\" onclick=\"surpriseMe()\">Try another</button>\n            <button class=\"btn-primary\" onclick=\"markDone('${esc(pick.id)}')\">We did this! ✓</button>\n          </div>\n        </div>\n      `);\n    };\n\n    // ── Mark done ─────────────────────────────────────────────────────────────\n    window.markDone = function(id) {\n      const idea = ideas.find(i => i.id === id);\n      if (!idea) return;\n      let rating = 0;\n      openModal(`\n        <h3>How was it?</h3>\n        <p style=\"margin-bottom:16px;color:var(--hub-text-muted,#6b7280)\">Rate <strong>${esc(idea.title)}</strong></p>\n        <div id=\"star-row\" class=\"star-row\" style=\"justify-content:center;margin-bottom:20px\">\n          ${[1,2,3,4,5].map(n => `<button class=\"star-btn\" onclick=\"setRating(${n})\" data-star=\"${n}\">☆</button>`).join(\"\")}\n        </div>\n        <div class=\"modal-actions\">\n          <button class=\"btn-secondary\" onclick=\"closeModal()\">Cancel</button>\n          <button id=\"confirm-done-btn\" class=\"btn-primary\" onclick=\"confirmDone('${esc(id)}')\">Mark as Done</button>\n        </div>\n      `);\n    };\n\n    window.setRating = function(n) {\n      document.querySelectorAll('.star-btn').forEach((btn, i) => {\n        btn.textContent = i < n ? \"★\" : \"☆\";\n      });\n      window._draftRating = n;\n    };\n\n    window.confirmDone = async function(id) {\n      const btn = document.getElementById(\"confirm-done-btn\");\n      if (btn) { btn.disabled = true; btn.textContent = \"Saving…\"; }\n      try {\n        const rating = window._draftRating ?? null;\n        if (ME) {\n          await db(\n            \"UPDATE date_ideas SET done_at = ?, rating = ? WHERE id = ?\",\n            [new Date().toISOString(), rating, id]\n          );\n          await loadIdeas();\n        }\n        window._draftRating = null;\n        closeModal();\n        renderIdeas();\n      } catch(e) {\n        if (btn) { btn.disabled = false; btn.textContent = \"Mark as Done\"; }\n        throw e;\n      }\n    };\n\n    // ── Tabs ──────────────────────────────────────────────────────────────────\n    window.switchTab = function(tab, btn) {\n      document.querySelectorAll(\".tab-btn\").forEach(b => b.classList.remove(\"active\"));\n      document.querySelectorAll(\".tab-panel\").forEach(p => p.classList.remove(\"active\"));\n      btn.classList.add(\"active\");\n      document.getElementById(`tab-${tab}`).classList.add(\"active\");\n    };\n\n    // ── Views ─────────────────────────────────────────────────────────────────\n    window.showSetup = function() {\n      const otherAdults = members.filter(m => m.role === \"adult\" && m.id !== (ME?.id ?? \"demo-1\"));\n      const listEl = document.getElementById(\"setup-members\");\n      listEl.innerHTML = otherAdults.map(m => {\n        const color = memberColor(m.id, members);\n        return `<label class=\"member-option\">\n          <input type=\"radio\" name=\"partner\" value=\"${esc(m.id)}\" />\n          <span class=\"member-avatar\" style=\"background:${color}\">${esc(initial(m.name))}</span>\n          <span class=\"member-name\">${esc(m.name)}</span>\n        </label>`;\n      }).join(\"\");\n      if (partner) {\n        const radio = listEl.querySelector(`input[value=\"${CSS.escape(partner.id)}\"]`);\n        if (radio) radio.checked = true;\n      }\n      document.getElementById(\"view-setup\").classList.add(\"active\");\n      document.getElementById(\"view-main\").classList.remove(\"active\");\n    };\n\n    function showMain() {\n      document.getElementById(\"view-setup\").classList.remove(\"active\");\n      document.getElementById(\"view-main\").classList.add(\"active\");\n      renderIdeas();\n    }\n\n    function renderIdeas() {\n      const undone  = ideas.filter(i => !i.done_at);\n      const done    = ideas.filter(i => i.done_at).sort((a,b) => b.done_at.localeCompare(a.done_at));\n\n      // Ideas tab\n      const ideasEl = document.getElementById(\"ideas-list\");\n      if (!undone.length) {\n        ideasEl.innerHTML = `<div class=\"empty-state\"><div class=\"empty-icon\">🌙</div><p>No ideas yet — add your first one!</p></div>`;\n      } else {\n        ideasEl.innerHTML = undone.map(idea => renderIdeaCard(idea, false)).join(\"\");\n      }\n\n      // History tab\n      const histEl = document.getElementById(\"history-list\");\n      if (!done.length) {\n        histEl.innerHTML = `<div class=\"empty-state\"><div class=\"empty-icon\">📖</div><p>No completed dates yet.</p></div>`;\n      } else {\n        histEl.innerHTML = done.map(idea => renderIdeaCard(idea, true)).join(\"\");\n      }\n    }\n\n    function renderIdeaCard(idea, isDone) {\n      const tags    = parseTags(idea.tags);\n      const tagsHtml = tags.length ? `<div class=\"idea-tags\">${tags.map(t => `<span class=\"idea-tag\">${esc(t)}</span>`).join(\"\")}</div>` : \"\";\n      const notesHtml = idea.notes ? `<div class=\"idea-notes\">${esc(idea.notes)}</div>` : \"\";\n      const starsHtml = idea.rating ? `<span class=\"stars\">${\"★\".repeat(idea.rating)}${\"☆\".repeat(5 - idea.rating)}</span>` : \"\";\n      const footer = isDone\n        ? `<div class=\"idea-footer\"><span class=\"idea-meta\">${formatRelativeDate(idea.done_at)}</span>${starsHtml}</div>`\n        : `<div class=\"idea-footer\"><span class=\"idea-meta\">${formatRelativeDate(idea.created_at)}</span>\n             <button class=\"btn-ghost\" onclick=\"markDone('${esc(idea.id)}')\">✓ Done</button>\n           </div>`;\n      return `\n        <div class=\"idea-card${isDone ? \" done\" : \"\"}\">\n          <div class=\"idea-header\"><span class=\"idea-title\">${esc(idea.title)}</span></div>\n          ${notesHtml}${tagsHtml}${footer}\n        </div>`;\n    }\n\n    // ── Init ──────────────────────────────────────────────────────────────────\n    (async () => {\n      await loadMembers();\n      partner = await loadPartner();\n      if (!partner) {\n        window.showSetup();\n      } else {\n        await loadIdeas();\n        showMain();\n      }\n    })();\n  </script>\n</body>\n</html>\n",
    "logic.js": "export const TAGS = [\"restaurant\", \"adventure\", \"stay-in\", \"outdoors\", \"culture\", \"budget\"];\n\nexport function validateIdea(title) {\n  const trimmed = (title ?? \"\").trim();\n  if (!trimmed) return { valid: false, trimmed: \"\" };\n  if (trimmed.length > 200) return { valid: false, trimmed };\n  return { valid: true, trimmed };\n}\n\nexport function parseTags(json) {\n  try { return Array.isArray(JSON.parse(json)) ? JSON.parse(json) : []; }\n  catch { return []; }\n}\n\nexport function pickRandom(ideas) {\n  if (!ideas.length) return null;\n  return ideas[Math.floor(Math.random() * ideas.length)];\n}\n"
  }
}